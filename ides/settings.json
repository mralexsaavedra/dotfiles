{
  // --- WORKBENCH & WINDOW ---
  "window.zoomLevel": 0.5,
  "window.titleBarStyle": "custom",
  "window.commandCenter": false,
  "window.autoDetectColorScheme": true,
  "workbench.startupEditor": "newUntitledFile",
  "workbench.activityBar.location": "top", // Use "hidden" for an even cleaner layout.
  "workbench.statusBar.visible": false,
  "workbench.layoutControl.enabled": false,
  "workbench.colorTheme": "GitHub Dark High Contrast",
  "workbench.preferredLightColorTheme": "GitHub Light",
  "workbench.preferredDarkColorTheme": "GitHub Dark High Contrast",
  // If you install Material Icon Theme, switch to "material-icon-theme".
  "workbench.iconTheme": "symbols",
  // If you install Carbon Product Icons, switch to "carbon-product-icons".
  "workbench.productIconTheme": "fluent-icons",
  "breadcrumbs.enabled": false,
  "telemetry.telemetryLevel": "off",

  // --- EDITOR: CORE EXPERIENCE ---
  "editor.minimap.enabled": false,
  "editor.wordWrap": "on",
  "editor.tabSize": 2,
  "editor.cursorBlinking": "expand",
  "editor.cursorSmoothCaretAnimation": "on",
  "editor.stickyScroll.enabled": true,
  "editor.bracketPairColorization.enabled": true,
  "editor.guides.bracketPairs": true,
  "editor.guides.indentation": true,
  "editor.renderWhitespace": "selection",

  // --- EDITOR: TYPOGRAPHY & THEMING ---
  "editor.fontFamily": "'CaskaydiaCove Nerd Font', monospace",
  // Enable ligatures (calt) and stylistic italics (ss01).
  "editor.fontLigatures": "'calt', 'ss01'",
  "editor.fontSize": 14,
  "editor.semanticHighlighting.enabled": true,
  "editor.inlayHints.enabled": "offUnlessPressed",
  "editor.inlineSuggest.enabled": true,
  "editor.quickSuggestions": {
    "other": true,
    "comments": false,
    "strings": true // Helpful for Tailwind classes in strings.
  },
  "workbench.colorCustomizations": {
    "editor.lineHighlightBackground": "#00000044",
    "editor.lineHighlightBorder": "#ffffff11"
  },
  "editor.tokenColorCustomizations": {
    "textMateRules": [
      {
        "scope": [
          "comment",
          "keyword",
          "storage",
          "storage.type",
          "entity.other.attribute-name",
          "variable.language.this",
          "variable.language.super"
        ],
        "settings": {
          "fontStyle": "italic"
        }
      }
    ]
  },

  // --- FILE EXPLORER & FILE TREE ---
  "explorer.fileNesting.enabled": true,
  "explorer.fileNesting.patterns": {
    "package.json": "package-lock.json, .npmrc, yarn.lock, pnpm-lock.yaml",
    "*.ts": "${capture}.js",
    "*.js": "${capture}.js.map, ${capture}.min.js, ${capture}.d.ts",
    "*.jsx": "${capture}.js",
    "*.tsx": "${capture}.ts",
    "requirements.txt": "requirements-dev.txt",
    ".env": ".env.*"
  },
  "explorer.confirmDelete": false,
  "explorer.confirmDragAndDrop": false,
  "files.exclude": {
    "**/.git": true,
    "**/.svn": true,
    "**/.hg": true,
    "**/CVS": true,
    "**/.DS_Store": true,
    "**/Thumbs.db": true,
    "**/__pycache__": true,
    "**/*.pyc": true
  },

  // --- FORMAT, LINT & IMPORT AUTOMATION ---
  "editor.formatOnSave": true,
  "editor.defaultFormatter": "esbenp.prettier-vscode",
  "editor.codeActionsOnSave": {
    "source.fixAll.eslint": "explicit" // Explicit is safer than always.
  },
  "prettier.requireConfig": true,
  "prettier.semi": false,
  "typescript.updateImportsOnFileMove.enabled": "always",
  "javascript.updateImportsOnFileMove.enabled": "always",
  "headwind.runOnSave": true,

  // --- SEARCH & WATCHER PERFORMANCE ---
  "search.exclude": {
    "**/node_modules": true,
    "**/dist": true,
    "**/.next": true,
    "**/build": true,
    "**/.venv": true,
    "**/__pycache__": true
  },
  "files.watcherExclude": {
    "**/node_modules/*/**": true,
    "**/.git/objects/**": true,
    "**/.venv/**": true
  },

  // --- GIT, EXTENSIONS & WORKSPACE TRUST ---
  "git.confirmSync": false,
  "git.autofetch": true,
  "extensions.ignoreRecommendations": true,
  "security.workspace.trust.untrustedFiles": "open",

  // --- INTEGRATED TERMINAL ---
  "terminal.integrated.defaultProfile.osx": "zsh",
  "terminal.integrated.fontFamily": "'CaskaydiaCove Nerd Font', 'Cascadia Code', monospace",
  "terminal.integrated.fontSize": 13,
  "terminal.integrated.lineHeight": 1.5,
  "terminal.integrated.fontLigatures.enabled": true,
  "terminal.integrated.cursorStyle": "line",
  "terminal.integrated.cursorBlinking": true,
  "terminal.integrated.gpuAcceleration": "on",
  "terminal.integrated.scrollback": 5000,
  "terminal.integrated.suggest.enabled": true,
  "terminal.integrated.showCommandHint": false,
  "terminal.integrated.allowedLinkSchemes": [
    "file",
    "http",
    "https",
    "mailto",
    "vscode",
    "vscode-insiders",
    "src/ui/app/components/Monitoring/FirebasePerformanceWrapper.native.tsx"
  ],

  // --- LANGUAGE-SPECIFIC OVERRIDES ---
  "[dockercompose]": {
    "editor.defaultFormatter": "redhat.vscode-yaml"
  },
  "[github-actions-workflow]": {
    "editor.defaultFormatter": "redhat.vscode-yaml"
  },
  "[python]": {
    "editor.defaultFormatter": "charliermarsh.ruff",
    "editor.formatOnSave": true,
    "editor.codeActionsOnSave": {
      "source.fixAll": "explicit",
      "source.organizeImports": "explicit"
    }
  }
}
